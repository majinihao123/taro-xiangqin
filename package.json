    "@tarojs/shared": "^4.2.0",
    "@tarojs/taro": "4.2.0",
    "babel-preset-taro": "^4.2.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.8.0",
